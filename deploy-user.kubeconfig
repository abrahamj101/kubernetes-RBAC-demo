apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://127.0.0.1:33417
  name: teleport-demo
contexts:
- context:
    cluster: teleport-demo
    namespace: nginx-app
    user: deploy-user
  name: deploy-user-context
current-context: deploy-user-context
kind: Config
users:
- name: deploy-user
  user:
    client-certificate-data: 
    client-key-data: 
